# ==========================================
# LeetCode Clone - Environment Variables
# ==========================================

# 1. Application URL
# When deployed to Vercel, change this to your production Vercel domain (e.g., https://my-leetcode-clone.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 2. Database (PostgreSQL)
# If using the provided docker-compose.yml on a VPS, the URL looks like this:
# format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/leetcode?schema=public"

# 3. Redis (BullMQ / WebSockets)
# If using the provided docker-compose.yml on a VPS, the URL looks like this:
REDIS_URL="redis://localhost:6379"

# 4. Authentication Secret
# Generate a strong random string for JWT signing
# You can generate one by running `openssl rand -base64 32` in your terminal
JWT_SECRET="your-super-secret-jwt-key"