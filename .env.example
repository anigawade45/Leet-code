# ==========================================
# LeetCode Clone - Environment Variables
# ==========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Rotate any credential that was previously hardcoded or committed.

# ------------------------------------------
# 1. Application URL
# ------------------------------------------
# When deployed to Vercel, change this to your production Vercel domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------
# 2. Database (PostgreSQL / Neon)
# ------------------------------------------
# format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=...
# PRODUCTION REQUIREMENT: Must include ?sslmode=verify-full (or sslmode=require)
# The app will REFUSE to start in production without an SSL-enabled URL.
DATABASE_URL="postgresql://postgres:password@localhost:5432/leetcode?schema=public"
# Production example (Neon):
# DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=verify-full"

# ------------------------------------------
# 3. Redis (BullMQ / WebSockets)
# ------------------------------------------
REDIS_URL="redis://localhost:6379"

# ------------------------------------------
# 4. Authentication
# ------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
# Optional overrides (defaults are fine for local dev)
# JWT_ISSUER="leetcode-app"
# JWT_AUD="leetcode-users"

# ------------------------------------------
# 5. Google Gemini AI
# ------------------------------------------
# Server-side only — NEVER prefix with NEXT_PUBLIC_
GEMINI_API_KEY="your-gemini-api-key"

# ------------------------------------------
# 6. Email (Resend)
# ------------------------------------------
# Server-side only — NEVER prefix with NEXT_PUBLIC_
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="onboarding@resend.dev"

# ------------------------------------------
# 7. Cloudinary (Image Uploads)
# ------------------------------------------
# All three are server-side only (used only in /api/upload)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ------------------------------------------
# 8. CORS / Socket Allowed Origins
# ------------------------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000"
SOCKET_ORIGINS="http://localhost:3000"

# ------------------------------------------
# 9. Socket Server (client-side, safe to expose)
# ------------------------------------------
# The WebSocket server URL — safe to be NEXT_PUBLIC_ (not a credential)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"